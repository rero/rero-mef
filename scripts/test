# COLORS for messages
NC='\033[0m'                    # Default color
INFO_COLOR='\033[1;97;44m'      # Bold + white + blue background
SUCCESS_COLOR='\033[1;97;42m'   # Bold + white + green background
ERROR_COLOR='\033[1;97;41m'     # Bold + white + red background

PROGRAM=`basename $0`
SCRIPT_PATH=`dirname $0`

# MESSAGES
msg() {
  echo -e "${1}" 1>&2
}
# Display a colored message
# More info: https://misc.flogisoft.com/bash/tip_colors_and_formatting
# $1: choosen color
# $2: title
# $3: the message
colored_msg() {
  msg "${1}[${2}]: ${3}${NC}"
}

info_msg() {
  colored_msg "${INFO_COLOR}" "INFO" "${1}"
}

error_msg() {
  colored_msg "${ERROR_COLOR}" "ERROR" "${1}"
}

error_msg+exit() {
    error_msg "${1}" && exit 1
}

success_msg() {
  colored_msg "${SUCCESS_COLOR}" "SUCCESS" "${1}"
}

# Displays program name-> Vulnerability found in py version 1.11.0
msg "PROGRAM: ${PROGRAM}"

# uv is a mandatory condition to launch this program!
if [[ -z "${VIRTUAL_ENV}" ]]; then
  error_msg+exit "Error - Launch this script via uv command:\n\uv run run-tests"
fi

pip_audit_exceptions=()
add_exceptions() {
  pip_audit_exceptions+=(--ignore-vuln "$1")
}

set -e

# Add exceptions below when a known vulnerability cannot yet be fixed.
# Format: add_exception "VULN-ID"  # reason and upstream issue link
info_msg "Check vulnerabilities:"
# urllib3 1.26.x -> 2.x upgrade blocked by invenio-search[elasticsearch7]
# which pins urllib3<2.0 via elasticsearch-py 7.x.
# CVE-2025-50181 (fixed 2.5.0): HTTP redirects not disabled when PoolManager is configured to
# disable them, potentially enabling SSRF or open-redirect bypass. Mitigation: rero-mef does not
# configure PoolManager-level redirect disabling; all outbound HTTP goes through trusted
# internal services or OAI endpoints where SSRF is not a concern.
add_exceptions "CVE-2025-50181"
# CVE-2025-66418 (fixed 2.6.0): unbounded number of links in the chained Content-Encoding
# decompression pipeline (e.g. Content-Encoding: gzip, zstd, gzip, …), enabling DoS via CPU/memory exhaustion.
# CVE-2025-66471 (fixed 2.6.0): streaming API improperly handles highly compressed data (decompression bomb).
# CVE-2026-21441 (fixed 2.6.3): streaming API drains and decompresses response bodies
# before the consumer reads them, bypassing configured read/size limits for any Content-Encoding.
# Mitigation: all HTTP traffic goes through a reverse proxy (HAProxy/Nginx)
# that enforces response size limits and strips unexpected Content-Encoding;
# no untrusted streaming responses are consumed directly.
add_exceptions "CVE-2025-66418"
add_exceptions "CVE-2025-66471"
add_exceptions "CVE-2026-21441"
# CVE-2026-44431 (fixed 2.7.0): sensitive headers (Authorization, Cookie, Proxy-Authorization)
# forwarded on cross-origin redirects via the low-level ProxyManager API with assert_same_host=False.
# Mitigation: rero-mef does not use ProxyManager with assert_same_host=False; all outbound HTTP
# goes through trusted internal services or OAI endpoints without cross-origin redirects.
# Upgrade blocked by elasticsearch-py 7.13.4 which pins urllib3<2.0;
# elasticsearch7 support cannot be dropped until the Invenio stack supports ES8/OpenSearch.
add_exceptions "CVE-2026-44431"
# sqlitedict 2.1.0 CVE-2024-35515 (no patched release):
# Insecure deserialization via pickle. Mitigated: SqliteDict is instantiated with
# encode=json.dumps / decode=json.loads, so pickle is never invoked.
add_exceptions "CVE-2024-35515"
# pytest 8.x CVE-2025-71176 (fixed in 9.0.3): local privilege escalation via predictable
# /tmp/pytest-of-{user} directory names. Upgrade blocked by pytest-invenio<4.0.0 which
# pins pytest<9.0.0. Mitigated: tests run in isolated environments with a single trusted
# user; no untrusted local users have access to the test runner's /tmp.
add_exceptions "CVE-2025-71176"
pip-audit "${pip_audit_exceptions[@]}"

info_msg "Test formatting:"
ruff format . --check
info_msg "Test linting:"
ruff check
info_msg "Tests:"
pytest --cov=rero_mef --cov-report=term-missing

success_msg "Perfect ${PROGRAM}! See you soon…"
exit 0
